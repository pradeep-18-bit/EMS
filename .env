# Local Docker Compose defaults for this repository.
COMPOSE_PROJECT_NAME=ems

BACKEND_IMAGE_NAME=ems-backend
BACKEND_IMAGE_TAG=local
FRONTEND_IMAGE_NAME=ems-frontend
FRONTEND_IMAGE_TAG=local

BACKEND_CONTAINER_NAME=ems-backend
FRONTEND_CONTAINER_NAME=ems-frontend
DOCKER_NETWORK_NAME=ems-network

BACKEND_UPLOADS_VOLUME_NAME=ems-backend-uploads
BACKEND_GENERATED_LETTERS_VOLUME_NAME=ems-backend-generated-letters
BACKEND_GENERATED_PAYSLIPS_VOLUME_NAME=ems-backend-generated-payslips

FRONTEND_PORT=8080
BACKEND_PORT=5007

BACKEND_BUILD_CONFIGURATION=Release
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
LIBREOFFICE_PATH=/usr/bin/soffice

# Keep this empty for the Docker nginx reverse-proxy setup.
VITE_API_ORIGIN=
VITE_APP_ENV=production

Cors__AllowedOriginsCsv=http://localhost:8080,http://localhost:5173,http://localhost:5174

# Optional secret overrides for Docker.
# Leave these commented if you want the backend to keep using appsettings.json locally.
# Uncomment and set real values before production deployment.
# ConnectionStrings__DefaultConnection=Server=host.docker.internal;Port=3306;Database=ems;User=ems_user;Password=ChangeMeNow123!;SslMode=None;
# Jwt__Key=EMS_Local_Replace_With_A_Long_Random_Key_At_Least_32_Chars
# Jwt__Issuer=EMS
# Jwt__Audience=EMSUsers
# EmailSettings__Host=smtp.gmail.com
# EmailSettings__Port=587
# EmailSettings__Username=noreply@example.com
# EmailSettings__Password=ReplaceWithYourMailAppPassword
