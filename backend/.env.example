# ASP.NET Core runtime environment used by the backend container.
ASPNETCORE_ENVIRONMENT=Production

# Kestrel listen URL inside the container.
ASPNETCORE_URLS=http://+:8080

# LibreOffice executable path used for DOCX to PDF conversion inside Linux containers.
LIBREOFFICE_PATH=/usr/bin/soffice

# Allowed frontend origins for browser requests.
# Use a comma-separated list if you serve the frontend from more than one domain.
Cors__AllowedOriginsCsv=http://localhost:8080,http://localhost:5173,http://localhost:5174

# Database connection string override for Docker or server deployment.
ConnectionStrings__DefaultConnection=Server=host.docker.internal;Port=3306;Database=ems;User=ems_user;Password=ChangeMeNow123!;SslMode=None;

# JWT settings consumed by the backend authentication configuration.
Jwt__Key=EMS_Local_Replace_With_A_Long_Random_Key_At_Least_32_Chars
Jwt__Issuer=EMS
Jwt__Audience=EMSUsers

# SMTP settings for email features.
EmailSettings__Host=smtp.gmail.com
EmailSettings__Port=587
EmailSettings__Username=noreply@example.com
EmailSettings__Password=ReplaceWithYourMailAppPassword
